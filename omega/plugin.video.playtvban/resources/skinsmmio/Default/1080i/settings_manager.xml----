<?xml version="1.0" encoding="UTF-8"?>
<window>
    <onload>SetFocus(2000,0,absolute)</onload>
    <controls>
        <!-- Background -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="FF000000">PLAYTVBAN_common/white.png</texture>
            <animation effect="fade" end="85" time="120">WindowOpen</animation>
        </control>
        <control type="group">
            <left>100</left>
            <top>30</top>
            <animation effect="fade" end="100" time="200">WindowOpen</animation>
            <!-- Logo and Background-->
            <control type="group">
                <control type="image">
                    <width>1720</width>
                    <height>1020</height>
                    <texture colordiffuse="$INFO[Window(10000).Property(PLAYTVBAN.window_theme)]" border="30">PLAYTVBAN_common/circle.png</texture>
                </control>
                <control type="image">
                    <left>12</left>
                    <top>12</top>
                    <width>40</width>
                    <height>40</height>
                    <align>left</align>
                    <aspectratio aligny="top">keep</aspectratio>
                    <texture>$INFO[Window(10000).Property(PLAYTVBAN.addon_icon_mini)]</texture>
                </control>
                <control type="label">
                    <width max="1700">auto</width>
                    <top>22</top>
                    <left>0</left>
                    <height>20</height>
                    <font>font12</font> <!-- PLAYTVBAN_26 -->
                    <textcolor>FFCCCCCC</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                    <label>[UPPERCASE][B]PLAYTVBAN - SETTINGS[/B][/UPPERCASE]</label>
                </control>
            </control>
            <control type="fixedlist" id="2000">
                <animation effect="slide" end="0,-340" time="0" condition="Integer.IsEqual(Container(2000).NumItems,1) | Integer.IsEqual(Container(2000).NumItems,2)">Conditional</animation>
                <animation effect="slide" end="0,-255" time="0" condition="Integer.IsEqual(Container(2000).NumItems,3) | Integer.IsEqual(Container(2000).NumItems,4)">Conditional</animation>
                <animation effect="slide" end="0,-170" time="0" condition="Integer.IsEqual(Container(2000).NumItems,5) | Integer.IsEqual(Container(2000).NumItems,6)">Conditional</animation>
                <animation effect="slide" end="0,-85" time="0" condition="Integer.IsEqual(Container(2000).NumItems,7) | Integer.IsEqual(Container(2000).NumItems,8)">Conditional</animation>
                <left>20</left>
                <top>100</top>
                <width>470</width>
                <height>765</height>
                <onleft>10025</onleft>
                <onright>SetFocus(2100,1,absolute)</onright>
                <onup>2000</onup>
                <ondown>2000</ondown>
                <orientation>Vertical</orientation>
                <focusposition>4</focusposition>
                <movement>4</movement>
                <scrolltime tween="cubic" easing="out">500</scrolltime>
                <itemlayout height="85" width="470">
                    <control type="label">
                        <left>40</left>
                        <width>390</width>
                        <height>85</height>
                        <label>[UPPERCASE]$INFO[ListItem.Property(setting_label)][/UPPERCASE]</label>
                        <font>font12</font> <!-- PLAYTVBAN_26 -->
                        <textcolor>FFCCCCCC</textcolor>
                        <aligny>center</aligny>
                    </control>
                </itemlayout>
                <focusedlayout height="85" width="470">
                    <control type="image">
                        <animation effect="fade" start="100" end="50" time="0" condition="!Control.HasFocus(2000)">Conditional</animation>
                        <height>85</height>
                        <width>470</width>
                        <texture colordiffuse="FFCCCCCC" border="30">PLAYTVBAN_common/circle.png</texture>
                    </control>
                    <control type="label">
                        <left>40</left>
                        <width>390</width>
                        <height>85</height>
                        <label>[UPPERCASE]$INFO[ListItem.Property(setting_label)][/UPPERCASE]</label>
                        <font>font12</font> <!-- PLAYTVBAN_26 -->
                        <textcolor>FF1F2020</textcolor>
                        <aligny>center</aligny>
                        <scroll>Control.HasFocus(2000)</scroll>
                    </control>
                </focusedlayout>
                <content>
                      <item id="10">
                          <property name="setting_label">General</property>
                      </item>
                      <item id="20">
                          <property name="setting_label">Features</property>
                      </item>
                      <item id="30">
                          <property name="setting_label">Content</property>
                      </item>
                      <item id="40">
                          <property name="setting_label">Single Episode Lists</property>
                      </item>
                      <item id="50">
                          <property name="setting_label">Meta Accounts</property>
                      </item>
                      <item id="60">
                          <property name="setting_label">Sources Accounts</property>
                      </item>
                      <item id="70">
                        <property name="setting_label">Results</property>
                      </item>
                      <item id="80">
                        <property name="setting_label">Playback</property>
                      </item>'
                </content>
            </control>
            <control type="fixedlist" id="2100">
                <animation effect="slide" end="0,-340" time="0" condition="Integer.IsEqual(Container(2100).NumItems,1) | Integer.IsEqual(Container(2100).NumItems,2)">Conditional</animation>
                <animation effect="slide" end="0,-255" time="0" condition="Integer.IsEqual(Container(2100).NumItems,3) | Integer.IsEqual(Container(2100).NumItems,4)">Conditional</animation>
                <animation effect="slide" end="0,-170" time="0" condition="Integer.IsEqual(Container(2100).NumItems,5) | Integer.IsEqual(Container(2100).NumItems,6)">Conditional</animation>
                <animation effect="slide" end="0,-85" time="0" condition="Integer.IsEqual(Container(2100).NumItems,7) | Integer.IsEqual(Container(2100).NumItems,8)">Conditional</animation>
                <left>520</left>
                <top>100</top>
                <width>1160</width>
                <height>765</height>
                <onleft>2000</onleft>
                <onleft>SetFocus(2100,1,absolute)</onleft>
                <onright>10025</onright>
                <pagecontrol>10025</pagecontrol>
                <orientation>Vertical</orientation>
                <focusposition>4</focusposition>
                <movement>4</movement>
                <scrolltime tween="cubic" easing="out">500</scrolltime>
                <itemlayout height="85" width="1160">
                    <!-- SEPARATOR -->
                    <control type="group">
                        <visible>String.IsEqual(ListItem.Property(setting_type),separator)</visible>
                        <control type="label">
                            <left>40</left>
                            <width>630</width>
                            <height>85</height>
                            <label>[UPPERCASE]$INFO[ListItem.Property(setting_label)][/UPPERCASE]</label>
                            <font>font12</font> <!-- PLAYTVBAN_26 -->
                            <textcolor>FFCCCCCC</textcolor>
                            <aligny>center</aligny>
                            <align>center</align>
                        </control>
                        <control type="image">
                            <top>70</top>
                            <left>30</left>
                            <height>2</height>
                            <width>1100</width>
                            <texture colordiffuse="FFCCCCCC">PLAYTVBAN_common/white.png</texture>
                        </control>
                    </control>
                    <!-- INFO ICON -->
                    <control type="image">
                        <visible>String.IsEqual(ListItem.Property(setting_type),info) + Control.HasFocus(2100)</visible>
                        <top>27</top>
                        <left>5</left>
                        <width>30</width>
                        <height>30</height>
                        <texture colordiffuse="FFCCCCCC">PLAYTVBAN_common/info.png</texture>
                    </control>
                    <!-- LABEL -->
                    <control type="label">
                        <visible>!String.IsEqual(ListItem.Property(setting_type),separator)</visible>
                        <left>40</left>
                        <width>630</width>
                        <height>85</height>
                        <label>[UPPERCASE]$INFO[ListItem.Property(setting_label)][/UPPERCASE]</label>
                        <font>font12</font> <!-- PLAYTVBAN_26 -->
                        <textcolor>FFCCCCCC</textcolor>
                        <aligny>center</aligny>
                        <scroll>false</scroll>
                    </control>
                    <!-- BOOLEAN -->
                    <control type="group">
                        <visible>String.IsEqual(ListItem.Property(setting_type),boolean)</visible>
                        <control type="image">
                            <visible>!String.IsEqual(ListItem.Property(setting_value),true)</visible>
                            <top>0</top>
                            <left>1030</left>
                            <width>150</width>
                            <align>right</align>
                            <aligny>center</aligny>
                            <aspectratio>keep</aspectratio>
                            <texture colordiffuse="FFCCCCCC">PLAYTVBAN_buttons/radio_button_off.png</texture>
                        </control>
                        <control type="image">
                            <visible>String.IsEqual(ListItem.Property(setting_value),true)</visible>
                            <top>0</top>
                            <left>1030</left>
                            <width>150</width>
                            <align>right</align>
                            <aligny>center</aligny>
                            <aspectratio>keep</aspectratio>
                            <texture colordiffuse="FFCCCCCC">PLAYTVBAN_buttons/radio_button_on.png</texture>
                        </control>
                    </control>
                    <!-- SETTING VALUE LABEL -->
                    <control type="group">
                        <visible>!String.IsEqual(ListItem.Property(setting_type),boolean)</visible>
                        <!-- EMPTY LABEL -->
                        <control type="label">
                            <visible>String.IsEqual(ListItem.Property(setting_value),empty_setting) + !String.IsEqual(ListItem.Property(setting_type),password)</visible>
                            <left>700</left>
                            <width>425</width>
                            <height>85</height>
                            <label>[B]...[/B]</label>
                            <font>font12</font> <!-- PLAYTVBAN_26 -->
                            <textcolor>FFCCCCCC</textcolor>
                            <align>right</align>
                            <aligny>center</aligny>
                            <scroll>Control.HasFocus(100)</scroll>
                        </control>
                        <!-- PASSWORD -->
                        <control type="label">
                            <visible>String.IsEqual(ListItem.Property(setting_type),password) + !String.IsEqual(ListItem.Property(setting_value),empty_setting) + !String.IsEmpty(ListItem.Property(setting_value))</visible>
                            <left>700</left>
                            <width>425</width>
                            <height>85</height>
                            <label>[B]********[/B]</label>
                            <font>font12</font> <!-- PLAYTVBAN_26 -->
                            <textcolor>FFCCCCCC</textcolor>
                            <align>right</align>
                            <aligny>center</aligny>
                            <scroll>Control.HasFocus(100)</scroll>
                        </control>
                        <!-- LABEL -->
                        <control type="label">
                            <visible>!String.IsEqual(ListItem.Property(setting_value),empty_setting) + !String.IsEqual(ListItem.Property(setting_type),password)</visible>
                            <left>700</left>
                            <width>425</width>
                            <height>85</height>
                            <label>[UPPERCASE][B]$INFO[ListItem.Property(setting_value)][/B][/UPPERCASE]</label>
                            <font>font12</font> <!-- PLAYTVBAN_26 -->
                            <textcolor>FFCCCCCC</textcolor>
                            <align>right</align>
                            <aligny>center</aligny>
                            <scroll>Control.HasFocus(100)</scroll>
                        </control>
                    </control>
                </itemlayout>
                <focusedlayout height="85" width="1160">
                    <!-- HIGHLIGHT -->
                    <control type="image">
                        <visible>Control.HasFocus(2100)</visible>
                        <height>85</height>
                        <width>1160</width>
                        <texture colordiffuse="FFCCCCCC" border="30">PLAYTVBAN_common/circle.png</texture>
                    </control>
                    <!-- SEPARATOR -->
                    <control type="group">
                        <visible>String.IsEqual(ListItem.Property(setting_type),separator)</visible>
                        <control type="label">
                            <left>40</left>
                            <width>630</width>
                            <height>85</height>
                            <label>[UPPERCASE]$INFO[ListItem.Property(setting_label)][/UPPERCASE]</label>
                            <font>font12</font> <!-- PLAYTVBAN_26 -->
                            <textcolor>FFCCCCCC</textcolor>
                            <aligny>center</aligny>
                            <align>center</align>
                        </control>
                        <control type="image">
                            <top>70</top>
                            <left>30</left>
                            <height>2</height>
                            <width>1100</width>
                            <texture colordiffuse="FFCCCCCC">PLAYTVBAN_common/white.png</texture>
                        </control>
                    </control>
                    <!-- INFO ICON -->
                    <control type="image">
                        <visible>String.IsEqual(ListItem.Property(setting_type),info) + Control.HasFocus(2100)</visible>
                        <top>27</top>
                        <left>5</left>
                        <width>30</width>
                        <height>30</height>
                        <texture colordiffuse="FF1F2020">PLAYTVBAN_common/info.png</texture>
                    </control>
                    <!-- LABEL -->
                    <control type="group">
                        <visible>!String.IsEqual(ListItem.Property(setting_type),separator)</visible>
                        <control type="label">
                            <visible>Control.HasFocus(2100)</visible>
                            <left>40</left>
                            <width>630</width>
                            <height>85</height>
                            <label>[UPPERCASE]$INFO[ListItem.Property(setting_label)][/UPPERCASE]</label>
                            <font>font12</font> <!-- PLAYTVBAN_26 -->
                            <textcolor>FF1F2020</textcolor>
                            <aligny>center</aligny>
                            <scroll>Control.HasFocus(2100)</scroll>
                        </control>
                        <control type="label">
                            <visible>!Control.HasFocus(2100)</visible>
                            <left>40</left>
                            <width>630</width>
                            <height>85</height>
                            <label>[UPPERCASE]$INFO[ListItem.Property(setting_label)][/UPPERCASE]</label>
                            <font>font12</font> <!-- PLAYTVBAN_26 -->
                            <textcolor>FFCCCCCC</textcolor>
                            <aligny>center</aligny>
                            <scroll>false</scroll>
                        </control>
                    </control>
                    <!-- BOOLEAN -->
                    <control type="group">
                        <visible>String.IsEqual(ListItem.Property(setting_type),boolean)</visible>
                        <control type="group">
                            <visible>!Control.HasFocus(2100)</visible>
                            <control type="image">
                                <visible>!String.IsEqual(ListItem.Property(setting_value),true)</visible>
                                <top>0</top>
                                <left>1030</left>
                                <width>150</width>
                                <align>right</align>
                                <aligny>center</aligny>
                                <aspectratio>keep</aspectratio>
                                <texture colordiffuse="FFCCCCCC">PLAYTVBAN_buttons/radio_button_off.png</texture>
                            </control>
                            <control type="image">
                                <visible>String.IsEqual(ListItem.Property(setting_value),true)</visible>
                                <top>0</top>
                                <left>1030</left>
                                <width>150</width>
                                <align>right</align>
                                <aligny>center</aligny>
                                <aspectratio>keep</aspectratio>
                                <texture colordiffuse="FFCCCCCC">PLAYTVBAN_buttons/radio_button_on.png</texture>
                            </control>
                        </control>
                        <control type="group">
                            <visible>Control.HasFocus(2100)</visible>
                            <control type="image">
                                <visible>!String.IsEqual(ListItem.Property(setting_value),true)</visible>
                                <top>0</top>
                                <left>1030</left>
                                <width>150</width>
                                <align>right</align>
                                <aligny>center</aligny>
                                <aspectratio>keep</aspectratio>
                                <texture colordiffuse="FF1F2020">PLAYTVBAN_buttons/radio_button_off.png</texture>
                            </control>
                            <control type="image">
                                <visible>String.IsEqual(ListItem.Property(setting_value),true)</visible>
                                <top>0</top>
                                <left>1030</left>
                                <width>150</width>
                                <align>right</align>
                                <aligny>center</aligny>
                                <aspectratio>keep</aspectratio>
                                <texture colordiffuse="FF1F2020">PLAYTVBAN_buttons/radio_button_on.png</texture>
                            </control>
                        </control>
                    </control>
                    <!-- SETTING VALUE LABEL -->
                    <control type="group">
                        <visible>!String.IsEqual(ListItem.Property(setting_type),boolean)</visible>
                        <!-- EMPTY LABEL -->
                        <control type="group">
                            <visible>String.IsEqual(ListItem.Property(setting_value),empty_setting) + !String.IsEqual(ListItem.Property(setting_type),password)</visible>
                            <control type="label">
                                <visible>Control.HasFocus(2100)</visible>
                                <left>700</left>
                                <width>425</width>
                                <height>85</height>
                                <label>[B]...[/B]</label>
                                <font>font12</font> <!-- PLAYTVBAN_26 -->
                                <textcolor>FF1F2020</textcolor>
                                <align>right</align>
                                <aligny>center</aligny>
                                <scroll>Control.HasFocus(2100)</scroll>
                            </control>
                            <control type="label">
                                <visible>!Control.HasFocus(2100)</visible>
                                <left>700</left>
                                <width>425</width>
                                <height>85</height>
                                <label>[B]...[/B]</label>
                                <font>font12</font> <!-- PLAYTVBAN_26 -->
                                <textcolor>FFCCCCCC</textcolor>
                                <align>right</align>
                                <aligny>center</aligny>
                                <scroll>false</scroll>
                            </control>
                        </control>
                        <!-- SETTING VALUE LABEL -->
                        <control type="group">
                            <visible>!String.IsEqual(ListItem.Property(setting_value),empty_setting)</visible>
                            <control type="label">
                                <visible>Control.HasFocus(2100) + String.IsEqual(ListItem.Property(setting_type),password) + !String.IsEqual(ListItem.Property(setting_value),empty_setting) + !String.IsEmpty(ListItem.Property(setting_value))</visible>
                                <left>700</left>
                                <width>425</width>
                                <height>85</height>
                                <label>[B]********[/B]</label>
                                <font>font12</font> <!-- PLAYTVBAN_26 -->
                                <textcolor>FF1F2020</textcolor>
                                <align>right</align>
                                <aligny>center</aligny>
                                <scroll>Control.HasFocus(2100)</scroll>
                            </control>
                            <control type="label">
                                <visible>!Control.HasFocus(2100) + String.IsEqual(ListItem.Property(setting_type),password) + !String.IsEqual(ListItem.Property(setting_value),empty_setting) + !String.IsEmpty(ListItem.Property(setting_value))</visible>
                                <left>700</left>
                                <width>425</width>
                                <height>85</height>
                                <label>[B]********[/B]</label>
                                <font>font12</font> <!-- PLAYTVBAN_26 -->
                                <textcolor>FFCCCCCC</textcolor>
                                <align>right</align>
                                <aligny>center</aligny>
                                <scroll>false</scroll>
                            </control>
                            <control type="label">
                                <visible>Control.HasFocus(2100) + !String.IsEqual(ListItem.Property(setting_type),password)</visible>
                                <left>700</left>
                                <width>425</width>
                                <height>85</height>
                                <label>[UPPERCASE][B]$INFO[ListItem.Property(setting_value)][/B][/UPPERCASE]</label>
                                <font>font12</font> <!-- PLAYTVBAN_26 -->
                                <textcolor>FF1F2020</textcolor>
                                <align>right</align>
                                <aligny>center</aligny>
                                <scroll>Control.HasFocus(2100)</scroll>
                            </control>
                            <control type="label">
                                <visible>!Control.HasFocus(2100) + !String.IsEqual(ListItem.Property(setting_type),password)</visible>
                                <left>700</left>
                                <width>425</width>
                                <height>85</height>
                                <label>[UPPERCASE][B]$INFO[ListItem.Property(setting_value)][/B][/UPPERCASE]</label>
                                <font>font12</font> <!-- PLAYTVBAN_26 -->
                                <textcolor>FFCCCCCC</textcolor>
                                <align>right</align>
                                <aligny>center</aligny>
                                <scroll>false</scroll>
                            </control>
                        </control>
                    </control>
                </focusedlayout>
                <content>
<!-- GENERAL 10-->
        <!-- General -->
                      <item>
                          <visible>Container(2000).HasFocus(10)</visible>
                          <property name="setting_label">General</property>
                          <property name="setting_type">separator</property>
                          <onclick>noop</onclick>
                     </item>
                      <item>
                          <visible>Container(2000).HasFocus(10)</visible>
                          <property name="setting_label">Autostart Play TVBan When Kodi Starts</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.auto_start_PLAYTVBAN)]</property>
                          <property name="setting_description">Enable this and Play TVBan will autostart after running its services upon Kodi start</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=auto_start_PLAYTVBAN)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(10)</visible>
                          <visible>String.EndsWith(Window(10000).Property(PLAYTVBAN.default_addon_fanart),Window(10000).Property(PLAYTVBAN.addon_fanart))</visible>
                          <property name="setting_label">Assign Addon Background Image</property>
                          <property name="setting_type">action</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.default_addon_fanart)]</property>
                          <property name="setting_description">Choose any custom background you would like to use within Play TVBan</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_path&amp;setting_id=default_addon_fanart)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(10)</visible>
                          <visible>!String.EndsWith(Window(10000).Property(PLAYTVBAN.default_addon_fanart),Window(10000).Property(PLAYTVBAN.addon_fanart))</visible>
                          <property name="setting_label">Restore Default Background Image</property>
                          <property name="setting_type">action</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.default_addon_fanart)]</property>
                          <property name="setting_description">Restore default Play TVBan background</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.restore_setting_default&amp;setting_id=default_addon_fanart)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(10)</visible>
                          <property name="setting_label">Limit Concurrent Threads</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.limit_concurrent_threads)]</property>
                          <property name="setting_description">Enable this and Play TVBan will limit the threads enacted simultaneously. Best to leave this disabled unless you are having issues with your device not supporting high numbers of concurrent threads in python</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=limit_concurrent_threads)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(10)</visible>
                          <visible>String.IsEqual(Window(10000).Property(PLAYTVBAN.limit_concurrent_threads),true)</visible>
                          <property name="setting_label">    - Maximum Active Threads</property>
                          <property name="setting_type">numeric</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.max_threads)]</property>
                          <property name="setting_description">Choose the maximum active concurrent threads Play TVBan will be limited to</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_numeric&amp;setting_id=max_threads)</onclick>
                      </item>
        <!-- Window Theme -->
                      <item>
                          <visible>Container(2000).HasFocus(10)</visible>
                          <property name="setting_label">Window Theme</property>
                          <property name="setting_type">separator</property>
                          <onclick>noop</onclick>
                     </item>
                      <item>
                          <visible>Container(2000).HasFocus(10)</visible>
                          <property name="setting_label">Assign Window Theme</property>
                          <property name="setting_type">action</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.window_theme_name)]</property>
                          <property name="setting_description">Choose the theme Play TVBan will use for custom windows. Choices are Light, Medium and Dark</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=window_theme_choice&amp;type=theme)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(10)</visible>
                          <property name="setting_label">Assign Window Theme Opacity</property>
                          <property name="setting_type">action</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.window_theme_opacity_name)]</property>
                          <property name="setting_description">Choose the Opacity Play TVBan will use for custom window themes. Choose between 10% - 100%</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=window_theme_choice&amp;type=opacity)</onclick>
                      </item>
        <!-- Watched Indicators -->
                      <item>
                          <visible>Container(2000).HasFocus(10)</visible>
                          <property name="setting_label">Watched Indicators</property>
                          <property name="setting_type">separator</property>
                          <onclick>noop</onclick>
                      </item>
                      <item>
