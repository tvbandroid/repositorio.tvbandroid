        <!-- Playback Utilities -->
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <property name="setting_label">Playback Utilities</property>
                          <property name="setting_type">separator</property>
                          <onclick>noop</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <property name="setting_label">Limit Resolve Attempts to Selected Result</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.playback.limit_resolve)]</property>
                          <property name="setting_description">Enable this and Play TVBan will limit the playback attempts to only the source result chosen. If disabled, Play TVBan will potentially try 15 results of similar properties to your chosen source result until it is able to successfully resolve and playback</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=playback.limit_resolve)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <visible>String.IsEqual(Window(10000).Property(PLAYTVBAN.provider.easynews),true)</visible>
                          <visible>![String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_user)) + String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_password))]</visible>
                          <property name="setting_label">EasyNews Playback Method</property>
                          <property name="setting_type">action</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.easynews.playback_method_name)]</property>
                          <property name="setting_description">Choose the method for Play TVBan to use to attempt optimal EasyNews playback. RETRY will retry once the link if it fails to resolve (slow). NO SEEK will tell Kodi the stream is not seekable. This results in quick and consistent resolving of the stream, but you will be unable to seek the stream outside of the cached data. Both is to use both methods. None is to use none of the methods.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_from_list&amp;setting_id=easynews.playback_method)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <visible>String.IsEqual(Window(10000).Property(PLAYTVBAN.provider.easynews),true)</visible>
                          <visible>![String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_user)) + String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_password))]</visible>
                          <visible>String.IsEqual(Window(10000).Property(PLAYTVBAN.easynews.playback_method),1) | String.IsEqual(Window(10000).Property(PLAYTVBAN.easynews.playback_method),3)</visible>
                          <property name="setting_label">    - Set Max. Retries for Playback</property>
                          <property name="setting_type">numeric</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.easynews.playback_method_retries)]</property>
                          <property name="setting_description">Choose the maximum retries allowed for EasyNews playback attempts</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_numeric&amp;setting_id=easynews.playback_method_retries)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <visible>String.IsEqual(Window(10000).Property(PLAYTVBAN.provider.easynews),true)</visible>
                          <visible>![String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_user)) + String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_password))]</visible>
                          <visible>String.IsEqual(Window(10000).Property(PLAYTVBAN.easynews.playback_method),2) | String.IsEqual(Window(10000).Property(PLAYTVBAN.easynews.playback_method),3)</visible>
                          <property name="setting_label">    - Exclude NO SEEK Playback for My Services</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.easynews.playback_method_limited)]</property>
                          <property name="setting_description">Enable this and Play TVBan will not use the NO SEEK EasyNews Playback Method when resolving regular files from the My Services->EasyNews location</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=easynews.playback_method_limited)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <property name="setting_label">Check Volume Before Start of Playback</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.playback.volumecheck_enabled)]</property>
                          <property name="setting_description">Enable this and Play TVBan will attempt to check the current level of volume within Kodi, and adjust it downwards if it is exceeding a set level</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=playback.volumecheck_enabled)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <visible>String.IsEqual(Window(10000).Property(PLAYTVBAN.playback.volumecheck_enabled),true)</visible>
                          <property name="setting_label">    - Set Max. Percent Starting Volume (0-100)</property>
                          <property name="setting_type">numeric</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.playback.volumecheck_percent)]</property>
                          <property name="setting_description">Choose the maximum allowed volume level</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_numeric&amp;setting_id=playback.volumecheck_percent)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <property name="setting_label">Subtitles</property>
                          <property name="setting_type">separator</property>
                          <onclick>noop</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <property name="setting_label">Auto Enable Subtitles</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.playback.auto_enable_subs)]</property>
                          <property name="setting_description">Turn on subtitles automatically during playback. When enabled, choose the subtitle source below</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=playback.auto_enable_subs)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <visible>String.IsEqual(Window(10000).Property(PLAYTVBAN.playback.auto_enable_subs),true)</visible>
                          <property name="setting_label">    - Subtitle Source</property>
                          <property name="setting_type">action</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.playback.subs_source_name)]</property>
                          <property name="setting_description">Local enables subtitles already embedded in or bundled with the stream. SubMaker and OpenSubtitles appear here when you have configured them below</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_from_list&amp;setting_id=playback.subs_source)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <visible>String.IsEqual(Window(10000).Property(PLAYTVBAN.playback.auto_enable_subs),true)</visible>
                          <visible>!String.IsEqual(Window(10000).Property(PLAYTVBAN.playback.subs_source),0)</visible>
                          <property name="setting_label">    - Prefer Local Subs</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.playback.submaker_prefer_local)]</property>
                          <property name="setting_description">When SubMaker or OpenSubtitles is the source, check for local subtitles first and keep them if already active instead of downloading</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=playback.submaker_prefer_local)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <visible>String.IsEqual(Window(10000).Property(PLAYTVBAN.playback.auto_enable_subs),true)</visible>
                          <property name="setting_label">    - Subtitle Language</property>
                          <property name="setting_type">action</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.playback.submaker_language_name)]</property>
                          <property name="setting_description">Preferred subtitle language for local embedded subs, SubMaker, and OpenSubtitles. Choose Forced Only (Local Subs) to enable forced embedded tracks only — SubMaker and OpenSubtitles still use English when that option is selected. For other languages, local subs try Play TVBan first, then Kodi Settings &gt; Player &gt; Language, then enable subs without forcing a track</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_from_list&amp;setting_id=playback.submaker_language)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <property name="setting_label">SubMaker</property>
                          <property name="setting_type">separator</property>
                          <onclick>noop</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <property name="setting_label">[I]submaker.elfhosted.com[/I]</property>
                          <property name="setting_type">info</property>
                          <property name="setting_value">...</property>
                          <property name="setting_description">ElfHosted SubMaker service. Enter your manifest URL below. Used when SubMaker is the Auto Enable Subtitle Source and as the first source for Subtitles Info alert timing background fetch. OpenSubtitles is used as a fallback when SubMaker is unavailable</property>
                          <onclick>noop</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <property name="setting_label">    - SubMaker Manifest URL</property>
                          <property name="setting_type">string</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.playback.submaker_manifest)]</property>
                          <property name="setting_description">Your full SubMaker manifest URL (must include manifest.json)</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_string&amp;setting_id=playback.submaker_manifest)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <property name="setting_label">OpenSubtitles</property>
                          <property name="setting_type">separator</property>
                          <onclick>noop</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <property name="setting_label">[I]OpenSubtitles.com Account[/I]</property>
                          <property name="setting_type">info</property>
                          <property name="setting_value">...</property>
                          <property name="setting_description">Free account at opensubtitles.com. Used when OpenSubtitles is the Auto Enable Subtitle Source and for Subtitles Info alert timing — after SubMaker when SubMaker is configured. Free accounts are limited to about 20 downloads per 24 hours; use Check OpenSubtitles Account to see your remaining quota</property>
                          <onclick>noop</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <property name="setting_label">    - Username</property>
                          <property name="setting_type">string</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.playback.opensubs_username)]</property>
                          <property name="setting_description">Your OpenSubtitles username for opensubtitles.com</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_string&amp;setting_id=playback.opensubs_username)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <property name="setting_label">    - Password</property>
                          <property name="setting_type">password</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.playback.opensubs_password)]</property>
                          <property name="setting_description">Your OpenSubtitles password for opensubtitles.com</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_string&amp;setting_id=playback.opensubs_password)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <visible>!String.IsEqual(Window(10000).Property(PLAYTVBAN.playback.opensubs_username),empty_setting)</visible>
                          <visible>!String.IsEqual(Window(10000).Property(PLAYTVBAN.playback.opensubs_password),empty_setting)</visible>
                          <property name="setting_label">    - Check OpenSubtitles Account...</property>
                          <property name="setting_type">action</property>
                          <property name="setting_value">...</property>
                          <property name="setting_description">Show your remaining OpenSubtitles download quota for the next 24 hours</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=opensubs_check_account)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <visible>!String.IsEqual(Window(10000).Property(PLAYTVBAN.playback.opensubs_username),empty_setting)</visible>
                          <visible>!String.IsEqual(Window(10000).Property(PLAYTVBAN.playback.opensubs_password),empty_setting)</visible>
                          <property name="setting_label">    - Revoke OpenSubtitles</property>
                          <property name="setting_type">action</property>
                          <property name="setting_value">...</property>
                          <property name="setting_description">Clear your saved OpenSubtitles username, password, and login token from Play TVBan</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=opensubs_revoke)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <property name="setting_label">    - Custom API Key (optional)</property>
                          <property name="setting_type">string</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.playback.opensubs_api_key)]</property>
                          <property name="setting_description">Play TVBan includes a built-in OpenSubtitles API key. Enter your own consumer key here only if you use a private OpenSubtitles consumer app</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_string&amp;setting_id=playback.opensubs_api_key)</onclick>
                      </item>
                </content>
            </control>
            <control type="group">
                <top>875</top>
                <left>15</left>
                <width>1685</width>
                <height>120</height>
                <!-- Match right-hand settings list vertical offset so INFO stays directly below it -->
                <animation effect="slide" end="0,-340" time="0" condition="Control.HasFocus(2100) + [Integer.IsEqual(Container(2100).NumItems,1) | Integer.IsEqual(Container(2100).NumItems,2)]">Conditional</animation>
                <animation effect="slide" end="0,-255" time="0" condition="Control.HasFocus(2100) + [Integer.IsEqual(Container(2100).NumItems,3) | Integer.IsEqual(Container(2100).NumItems,4)]">Conditional</animation>
                <animation effect="slide" end="0,-170" time="0" condition="Control.HasFocus(2100) + [Integer.IsEqual(Container(2100).NumItems,5) | Integer.IsEqual(Container(2100).NumItems,6)]">Conditional</animation>
                <animation effect="slide" end="0,-85" time="0" condition="Control.HasFocus(2100) + [Integer.IsEqual(Container(2100).NumItems,7) | Integer.IsEqual(Container(2100).NumItems,8)]">Conditional</animation>
                <animation effect="slide" end="0,-340" time="0" condition="Control.HasFocus(2000) + [Integer.IsEqual(Container(2000).NumItems,1) | Integer.IsEqual(Container(2000).NumItems,2)]">Conditional</animation>
                <animation effect="slide" end="0,-255" time="0" condition="Control.HasFocus(2000) + [Integer.IsEqual(Container(2000).NumItems,3) | Integer.IsEqual(Container(2000).NumItems,4)]">Conditional</animation>
                <animation effect="slide" end="0,-170" time="0" condition="Control.HasFocus(2000) + [Integer.IsEqual(Container(2000).NumItems,5) | Integer.IsEqual(Container(2000).NumItems,6)]">Conditional</animation>
                <animation effect="slide" end="0,-85" time="0" condition="Control.HasFocus(2000) + [Integer.IsEqual(Container(2000).NumItems,7) | Integer.IsEqual(Container(2000).NumItems,8)]">Conditional</animation>
                <control type="image">
                    <top>0</top>
                    <left>0</left>
                    <width>1685</width>
                    <height>120</height>
                    <texture colordiffuse="FF1A1A1A" border="20">PLAYTVBAN_common/circle.png</texture>
                </control>
                <control type="label">
                    <top>12</top>
                    <left>30</left>
                    <width>200</width>
                    <height>24</height>
                    <font>font12</font> <!-- PLAYTVBAN_26 -->
                    <textcolor>FFCCCCCC</textcolor>
                    <label>[UPPERCASE][B]INFO: [/B][/UPPERCASE]</label>
                    <align>left</align>
                    <aligny>top</aligny>
                </control>
                <control type="group">
                    <top>8</top>
                    <left>115</left>
                    <width>1530</width>
                    <height>104</height>
                    <control type="textbox">
                        <left>0</left>
                        <top>0</top>
                        <width>1530</width>
                        <height>104</height>
                        <font>font12</font> <!-- PLAYTVBAN_26 -->
                        <align>left</align>
                        <aligny>top</aligny>
                        <textcolor>FFCCCCCC</textcolor>
                        <scrolltime>300</scrolltime>
                        <label>$INFO[Container(2100).ListItem.Property(setting_description)]</label>
                        <autoscroll delay="2000" time="2500" repeat="7000">true</autoscroll>
                        <visible>Control.HasFocus(2100)</visible>
                    </control>
                    <control type="textbox">
                        <left>0</left>
                        <top>0</top>
                        <width>1530</width>
                        <height>104</height>
                        <font>font12</font> <!-- PLAYTVBAN_26 -->
                        <align>left</align>
                        <aligny>top</aligny>
                        <textcolor>FFCCCCCC</textcolor>
                        <scrolltime>300</scrolltime>
                        <label>$INFO[Container(2000).ListItem.Property(setting_label),All settings related to [UPPERCASE][B],[/B][/UPPERCASE] settings]</label>
                        <autoscroll delay="2000" time="2500" repeat="7000">true</autoscroll>
                        <visible>Control.HasFocus(2000)</visible>
                    </control>
                </control>
            </control>
            <control type="scrollbar" id="10025">
                <top>100</top>
                <left>1700</left>
                <width>10</width>
                <height>760</height>
                <texturesliderbackground colordiffuse="FF302F2F">PLAYTVBAN_common/white.png</texturesliderbackground>
                <texturesliderbar colordiffuse="FF555556">PLAYTVBAN_common/white.png</texturesliderbar>
                <texturesliderbarfocus colordiffuse="FFCCCCCC">PLAYTVBAN_common/white.png</texturesliderbarfocus>
                <onleft>2100</onleft>
                <onright>2000</onright>
                <showonepage>false</showonepage>
                <orientation>vertical</orientation>
            </control>
        </control>
    </controls>
</window>
