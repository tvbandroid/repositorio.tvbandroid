                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(60)</visible>
                          <visible>String.IsEqual(Window(10000).Property(PLAYTVBAN.provider.easynews),true)</visible>
                          <visible>![String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_user)) + String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_password))]</visible>
                          <property name="setting_label">Filter Results by Name</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.easynews.title_filter)]</property>
                          <property name="setting_description">After EasyNews returns results, match filenames against the movie or episode title (and aliases). EasyNews search is already narrow (e.g. Movie Year or Show S01E05), so this often removes few extra results but helps when unrelated files slip through. Disable if valid links go missing. Search Width, Filter Languages, and Fallback Search Queries usually matter more for EasyNews</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=easynews.title_filter)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(60)</visible>
                          <visible>String.IsEqual(Window(10000).Property(PLAYTVBAN.provider.easynews),true)</visible>
                          <visible>![String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_user)) + String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_password))]</visible>
                          <property name="setting_label">Filter Languages</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.easynews.filter_lang)]</property>
                          <property name="setting_description">Enable this and Play TVBan will perform extra language filtering on your EasyNews results. Will help to limit incorrect results, but may also filter some relevant results</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=easynews.filter_lang)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(60)</visible>
                          <visible>String.IsEqual(Window(10000).Property(PLAYTVBAN.provider.easynews),true)</visible>
                          <visible>![String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_user)) + String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_password))]</visible>
                          <property name="setting_label">Exclude Adult Results</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.easynews.exclude_adult)]</property>
                          <property name="setting_description">Enable to request Safe Search filtering from EasyNews and exclude adult results from EasyNews queries.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=easynews.exclude_adult)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(60)</visible>
                          <visible>String.IsEqual(Window(10000).Property(PLAYTVBAN.provider.easynews),true)</visible>
                          <visible>![String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_user)) + String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_password))]</visible>
                          <visible>String.IsEqual(Window(10000).Property(PLAYTVBAN.easynews.filter_lang),true)</visible>
                          <property name="setting_label">    - Choose Languages To Include</property>
                          <property name="setting_type">action</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.easynews.lang_filters)]</property>
                          <property name="setting_description">Choose which languages you wish to include in EasyNews results</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=set_language_filter_choice&amp;filter_setting_id=easynews.lang_filters&amp;multi_choice=true)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(60)</visible>
                          <visible>String.IsEqual(Window(10000).Property(PLAYTVBAN.provider.easynews),true)</visible>
                          <visible>![String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_user)) + String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_password))]</visible>
                          <visible>String.IsEqual(Window(10000).Property(PLAYTVBAN.easynews.filter_lang),true)</visible>
                          <property name="setting_label">    - Include Unknown Language Results</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.easynews.lang_include_unknown)]</property>
                          <property name="setting_description">When language filtering is enabled, keep files EasyNews does not report a language for. Disable to exclude them (strict filtering)</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=easynews.lang_include_unknown)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(60)</visible>
                          <visible>String.IsEqual(Window(10000).Property(PLAYTVBAN.provider.easynews),true)</visible>
                          <visible>![String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_user)) + String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_password))]</visible>
                          <property name="setting_label">Refresh Credentials Each Request</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.easynews.refresh_credentials)]</property>
                          <property name="setting_description">Reload your EasyNews username and password from Play TVBan settings before every Solr search and before resolving or downloading a file. Kodi normally keeps the login in memory for the session; enable this if you change your EasyNews password on the website, edit credentials in settings, or share a profile and want the next search to use the updated login without restarting Kodi. Expect a small extra delay per request when enabled</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=easynews.refresh_credentials)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(60)</visible>
                          <visible>String.IsEqual(Window(10000).Property(PLAYTVBAN.provider.easynews),true)</visible>
                          <visible>![String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_user)) + String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_password))]</visible>
                          <property name="setting_label">Fallback Search Queries</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.easynews.fallback_search)]</property>
                          <property name="setting_description">If the main Search Width queries return no files, run extra EasyNews searches using TMDB alternate titles (aliases). For TV: alias plus episode (e.g. Show S01E05) and alias plus season (Show S01). For movies: alias plus release year. Only queries not already tried are used. Helpful when EasyNews filenames use a different show name than TMDB. Usually unnecessary if Search Width is Broad, because Broad already searches aliases. Default is on</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=easynews.fallback_search)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(60)</visible>
                          <visible>String.IsEqual(Window(10000).Property(PLAYTVBAN.provider.easynews),true)</visible>
                          <visible>![String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_user)) + String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_password))]</visible>
                          <property name="setting_label">Search Width</property>
                          <property name="setting_type">action</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.easynews.search_width_name)]</property>
                          <property name="setting_description">How many EasyNews Solr searches to run per movie or episode. Results are merged and duplicates removed. Focused (fastest): one query only — Movie: Title Year (e.g. Dune 2021); TV: Title S01E05 (e.g. Breaking Bad S01E05). Balanced: Focused plus a wider query — Movie: title without year; TV: Title S01 (all episodes in that season on EasyNews). Broad (slowest, best recall): Balanced plus show or movie title only, then the same patterns for each TMDB alias. Broad pulls many unrelated files for short titles; keep Filter Results by Name enabled. More width means more API calls and a longer source search</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_from_list&amp;setting_id=easynews.search_width)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(60)</visible>
                          <visible>String.IsEqual(Window(10000).Property(PLAYTVBAN.provider.easynews),true)</visible>
                          <visible>![String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_user)) + String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_password))]</visible>
                          <property name="setting_label">Check Before Full Search</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.check.easynews)]</property>
                          <property name="setting_description">Query EasyNews early in the source search, before external torrent scrapers and the rest of the internal scrape list. The progress window can show EasyNews quality counts (4K, 1080p, etc.) while torrent scrapers are still running. If EasyNews returns results during this prescrape step, you may get playable links sooner instead of waiting for the full scrape to finish. Does not replace external scrapers — it runs EasyNews first, then the normal search continues. Often used in conjunction with Autoplay Result, below (when Check Before Full Search is enabled).</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=check.easynews)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(60)</visible>
                          <visible>String.IsEqual(Window(10000).Property(PLAYTVBAN.provider.easynews),true)</visible>
                          <visible>![String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_user)) + String.IsEmpty(Window(10000).Property(PLAYTVBAN.easynews_password))]</visible>
                          <visible>String.IsEqual(Window(10000).Property(PLAYTVBAN.check.easynews),true)</visible>
                          <property name="setting_label">    - Autoplay Result</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(PLAYTVBAN.autoplay.easynews)]</property>
                          <property name="setting_description">Enable this and Play TVBan will Autoplay the top result found from EasyNews</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=autoplay.easynews)</onclick>
                      </item>
