                          <property name="setting_type">action</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.recommend_seed_name)]</property>
                          <property name="setting_description">Elige qué porcentaje del contenido multimedia que has visto anteriormente se utilizará para las recomendaciones del menú "Porque viste contenido aleatorio".</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_from_list&amp;setting_id=recommend_seed)</onclick>
                      </item>
