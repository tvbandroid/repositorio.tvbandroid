                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.meta_filter)]</property>
                          <property name="setting_description">Habilita esta opción para que Play TVBan intente filtrar contenido para adultos en las búsquedas de películas, series y personas. La eficacia depende exclusivamente de la precisión de la base de datos de TMDb.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=meta_filter)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(30)</visible>
