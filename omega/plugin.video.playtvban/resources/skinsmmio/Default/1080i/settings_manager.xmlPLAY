                          <property name="setting_description">Introduce aquí la velocidad de tu línea de internet. Es recomendable elegir un valor ligeramente inferior a tu velocidad real de internet, aunque Play TVBan reducirá este valor en un 10 % antes de filtrar los resultados por tamaño.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_numeric&amp;setting_id=results.line_speed)</onclick>
                      </item>
