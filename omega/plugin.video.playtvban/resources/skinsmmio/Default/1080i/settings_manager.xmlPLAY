                          <property name="setting_description">Habilita esta opción para que Play TVBan oculte las miniaturas y las sinopsis de los episodios.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=avoid_episode_spoilers)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(30)</visible>
                          <property name="setting_label">Incluir anime en el Progreso de Series Vistas</property>
