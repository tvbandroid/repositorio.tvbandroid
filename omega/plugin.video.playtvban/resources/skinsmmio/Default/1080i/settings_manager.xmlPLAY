                          <visible>String.IsEqual(Window(10000).Property(playtvban.oc.token),empty_setting)</visible>
                          <property name="setting_label">Autorizar</property>
                          <property name="setting_type">action</property>
                          <property name="setting_value">...</property>
                          <property name="setting_description">Autoriza tu cuenta de Offcloud con un código QR y úsala dentro de Play TVBan.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=offcloud.authenticate)</onclick>
                      </item>
                      <item>
