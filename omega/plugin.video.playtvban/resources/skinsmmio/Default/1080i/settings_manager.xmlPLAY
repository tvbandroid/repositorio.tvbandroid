                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.autoplay.folders)]</property>
                          <property name="setting_description">Habilita esta opción y Play TVBan Reproducirá Automáticamente el mejor resultado encontrado en las Carpetas Locales.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=autoplay.folders)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(60)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.provider.folders),true)</visible>
