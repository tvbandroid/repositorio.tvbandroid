                          <visible>!String.IsEqual(Window(10000).Property(playtvban.oc.token),empty_setting)</visible>
                          <property name="setting_label">Habilitar</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.oc.enabled)]</property>
                          <property name="setting_description">Habilita el uso de tu cuenta Offcloud.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=oc.enabled)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(60)</visible>
                          <visible>!String.IsEqual(Window(10000).Property(playtvban.oc.token),empty_setting)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.oc.enabled),true)</visible>
                          <property name="setting_label">Revocar Autorización</property>
                          <property name="setting_type">action</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.oc.token)]</property>
