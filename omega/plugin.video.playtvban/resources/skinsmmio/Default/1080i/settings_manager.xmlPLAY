                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.paginate.limit_widgets)]</property>
                          <property name="setting_description">Seleccione el límite de paginación para los widgets de Play TVBan.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_numeric&amp;setting_id=paginate.limit_widgets)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(30)</visible>
                          <property name="setting_label">Habilitar Salto a la Navegación</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.paginate.jump_to)]</property>
                          <property name="setting_description">Habilite esta opción y Play TVBan incluirá un elemento "Saltar a..." al final de cada página de las listas personales paginadas. Puede usar esto para saltar a una página específica en la lista.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=paginate.jump_to)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(30)</visible>
                          <property name="setting_label">Ignorar Artículos al Ordenar Listas</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.ignore_articles)]</property>
                          <property name="setting_description">Habilita esta opción y Play TVBan ignorará palabras clave como "The" y "A" al ordenar las listas.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=ignore_articles)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(30)</visible>
                          <property name="setting_label">Servicio utilizado Porque lo Viste</property>
                          <property name="setting_type">action</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.recommend_service_name)]</property>
                          <property name="setting_description">Elige el servicio que te ofrece recomendaciones para los menús de "Porque viste este vídeo". Las opciones son: Recomendado (TMDb), Más vídeos similares (IMDb) o Similares según IA (IA).</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_from_list&amp;setting_id=recommend_service)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(30)</visible>
