                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_from_list&amp;setting_id=default_all_episodes)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(30)</visible>
                          <property name="setting_label">Evitar Spoilers de Episodios</property>
