                          <visible>String.IsEqual(Window(10000).Property(playtvban.provider.external),true)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.tb.cache_check),true)</visible>
                          <property name="setting_label">Incluir Resultados No Almacenados en Cache (Rastreadores Externos)</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.tb.include_uncached)]</property>
                          <property name="setting_description">Cuando está activada, los torrents que no están en la caché compartida de TorBox también aparecen en la lista principal de resultados (sujeto a un número mínimo de seeders). Al seleccionar una fila que no está en caché, se añade a tu nube de TorBox.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=tb.include_uncached)</onclick>
                      </item>
