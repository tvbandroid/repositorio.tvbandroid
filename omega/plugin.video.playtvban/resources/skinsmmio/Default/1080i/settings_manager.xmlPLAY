                          <visible>String.IsEqual(Window(10000).Property(playtvban.provider.folders),true)</visible>
                          <property name="setting_label">Ignorar los Filtros de Calidad y Tamaño.</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.results.folders_ignore_filters)]</property>
                          <property name="setting_description">Habilita esta opción y Play TVBan ignorará cualquier filtro de calidad o tamaño al procesar los resultados de las carpetas de medios locales.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=results.folders_ignore_filters)</onclick>
                      </item>
