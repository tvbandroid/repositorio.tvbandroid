                      <item>
                          <visible>Container(2000).HasFocus(20)</visible>
                          <visible>!String.IsEqual(Window(10000).Property(playtvban.google_api),empty_setting) | !String.IsEqual(Window(10000).Property(playtvban.groq_api),empty_setting)</visible>
                          <property name="setting_label">Seleccione las Prioridades del Modelo de IA</property>
                          <property name="setting_type">action</property>
                          <property name="setting_value">...</property>
                          <property name="setting_description">Elige el orden en que se usarán los modelos de IA para títulos similares. El primero se usará y el último, el primero. Normalmente, querrás mantener este orden por defecto. Si no tienes una clave API para el modelo que aparece en la lista, se omitirá.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=ai_model_order_choice)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(20)</visible>
                          <visible>!String.IsEqual(Window(10000).Property(playtvban.google_api),empty_setting) | !String.IsEqual(Window(10000).Property(playtvban.groq_api),empty_setting)</visible>
                          <property name="setting_label">Seleccione el Máximo de Resultados Similares a los Títulos</property>
                          <property name="setting_type">numeric</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.ai_model.limit)]</property>
                          <property name="setting_description">Seleccione el número máximo de resultados similares de IA que devuelve Play TVBan.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_numeric&amp;setting_id=ai_model.limit)</onclick>
                      </item>
<!-- CONTENT 30 -->
        <!-- General -->
                      <item>
                          <visible>Container(2000).HasFocus(30)</visible>
                          <property name="setting_label">General</property>
                          <property name="setting_type">separator</property>
                          <onclick>noop</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(30)</visible>
                          <property name="setting_label">Paginar listas Cuando esté Disponible</property>
                          <property name="setting_type">action</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.paginate.lists_name)]</property>
                          <property name="setting_description">Active esta opción para que Play TVBan intente paginar las listas cuando sea posible. Esto se aplica principalmente a las listas personales.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_from_list&amp;setting_id=paginate.lists)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(30)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.paginate.lists),1) | String.IsEqual(Window(10000).Property(playtvban.paginate.lists),3)</visible>
                          <property name="setting_label">    - Límite de Elementos del Addon</property>
                          <property name="setting_type">numeric</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.paginate.limit_addon)]</property>
                          <property name="setting_description">Seleccione el límite de paginación dentro de Play TVBan.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_numeric&amp;setting_id=paginate.limit_addon)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(30)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.paginate.lists),2) | String.IsEqual(Window(10000).Property(playtvban.paginate.lists),3)</visible>
                          <property name="setting_label">    - Límite de Elementos de Widgets</property>
