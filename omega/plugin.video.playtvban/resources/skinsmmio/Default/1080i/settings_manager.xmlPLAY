                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.manual_viewtypes)]</property>
                          <property name="setting_description">Habilite esta opción para introducir manualmente los valores de los tipos de vista utilizados. Solo hágalo si conoce los valores de los tipos de vista del tema que está utilizando. De lo contrario, utilice el menú "Configurar vistas" en Herramientas.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=manual_viewtypes)</onclick>
                      </item>
