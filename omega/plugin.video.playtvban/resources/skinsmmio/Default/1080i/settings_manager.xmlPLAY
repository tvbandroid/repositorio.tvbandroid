                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_numeric&amp;setting_id=results.timeout)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(70)</visible>
                          <property name="setting_label">Formato de Visualización de Resultados</property>
                          <property name="setting_type">action</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.results.list_format)]</property>
                          <property name="setting_description">Elija el formato en el que Play TVBan mostrará los resultados de una búsqueda de fuentes. Se ofrecen listas, filas y listas anchas.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=results_format_choice)</onclick>
                      </item>
        <!-- Rescrape -->
                      <item>
                          <visible>Container(2000).HasFocus(70)</visible>
                          <property name="setting_label">Reescaneo de Acciones</property>
                          <property name="setting_type">separator</property>
                          <onclick>noop</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(70)</visible>
                          <property name="setting_label">Reescaneo de Acciones</property>
                          <property name="setting_type">action</property>
                          <property name="setting_value">...</property>
                          <property name="setting_description">Configure reintentos automáticos cuando una búsqueda de fuente no devuelva resultados reproducibles. Cada acción puede ser Desactivado, Automático o Avisar, con orden de mayor a menor. Volver a raspar Sin comprobación de caché desactiva las comprobaciones de caché externas por proveedor (Real Debrid, All Debrid, TorBox, Premiumize, Offcloud). Volver a raspar Con proveedores externos deshabilitados incluye proveedores de torrents externos deshabilitados (no raspadores internos como EasyNews o debrid cloud). Ofrecer búsqueda completa después de los primeros resultados se aplica solo a la ruta de reintento de búsqueda vacía; Comprobar Antes de la Búsqueda Completa y Ejecutar Búsqueda de Raspador Externo durante el pre-rastreo son independientes.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=rescrape_actions_choice)</onclick>
                      </item>
        <!-- Sorting and Filtering -->
