                      <item>
                          <visible>Container(2000).HasFocus(30)</visible>
                          <property name="setting_label">Incluir Contenido no Emitido en las Listas de Seguimiento de Trakt</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.show_unaired_watchlist)]</property>
                          <property name="setting_description">Habilita esta opción para mostrar contenido aún no emitido en sus listas de seguimiento de películas y series de Trakt. Si la desactiva, dicho contenido permanecerá oculto.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=show_unaired_watchlist)</onclick>
                      </item>
