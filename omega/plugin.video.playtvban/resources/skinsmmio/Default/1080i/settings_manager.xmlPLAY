                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.results.sort_folders_first)]</property>
                          <property name="setting_description">Habilita esta opción y Play TVBan ordenará los resultados de tus carpetas de medios locales al principio de todos los resultados.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=results.sort_folders_first)</onclick>
                      </item>
                      <item>
