        <!-- EasyNews -->
                      <item>
                          <visible>Container(2000).HasFocus(60)</visible>
                          <property name="setting_label">EasyNews</property>
                          <property name="setting_type">separator</property>
                          <onclick>noop</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(60)</visible>
                          <property name="setting_label">Habilitar</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.provider.easynews)]</property>
                          <property name="setting_description">Habilite el uso de su cuenta de EasyNews</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=provider.easynews)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(60)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.provider.easynews),true)</visible>
                          <property name="setting_label">Usuario</property>
