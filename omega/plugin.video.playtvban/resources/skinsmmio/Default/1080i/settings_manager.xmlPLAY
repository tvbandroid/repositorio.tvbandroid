                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=offcloud.revoke_authentication)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(60)</visible>
                          <visible>!String.IsEqual(Window(10000).Property(playtvban.oc.token),empty_setting)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.oc.enabled),true)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.provider.external),true)</visible>
                          <property name="setting_label">Comprobar el Estado de la Cache (Rastreadores Externos)</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.oc.cache_check)]</property>
                          <property name="setting_description">Cuando está activada, Play TVBan comprueba si los resultados de torrents externos están almacenados en caché en tu cuenta de Offcloud antes de mostrarlos. Es posible que veas menos enlaces, pero los que se muestren deberían cargarse al instante.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=oc.cache_check)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(60)</visible>
                          <visible>!String.IsEqual(Window(10000).Property(playtvban.oc.token),empty_setting)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.oc.enabled),true)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.provider.external),true)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.oc.cache_check),true)</visible>
                          <property name="setting_label">Incluir Resultados No Almacenados en Cache (Rastreadores Externos)</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.oc.include_uncached)]</property>
                          <property name="setting_description">Cuando está activada, los torrents que no están en la caché instantánea de Offcloud también aparecen en la lista principal de resultados (sujeto a un número mínimo de seeders). Al seleccionar una fila que no está en caché, se añade a tu nube de Offcloud.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=oc.include_uncached)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(60)</visible>
                          <visible>!String.IsEqual(Window(10000).Property(playtvban.oc.token),empty_setting)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.oc.enabled),true)</visible>
                          <property name="setting_label">Agregar Cache de Debrid Resuelto a la Nube</property>
                          <property name="setting_type">action</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.store_resolved_to_cloud.offcloud_name)]</property>
                          <property name="setting_description">Elige qué contenido multimedia resuelto se añade automáticamente a tu nube Offcloud. Todo el contenido multimedia o solo los paquetes de programas.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_from_list&amp;setting_id=store_resolved_to_cloud.offcloud)</onclick>
