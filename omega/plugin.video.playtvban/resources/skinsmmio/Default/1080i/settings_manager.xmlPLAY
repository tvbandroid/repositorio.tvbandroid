                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.tb.cache_check)]</property>
                          <property name="setting_description">Cuando está activada, Play TVBan comprueba si los resultados de torrents externos están almacenados en caché en tu cuenta de TorBox antes de mostrarlos. Es posible que veas menos enlaces, pero los que se muestren deberían cargarse al instante.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=tb.cache_check)</onclick>
                      </item>
