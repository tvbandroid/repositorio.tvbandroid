                          <property name="setting_description">Habilita esta opción para incluir contenido de anime en los menús Vistos, En progreso, Episodios en progreso y Próximos episodios dentro del menú principal de Series.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=include_anime_tvshow)</onclick>
