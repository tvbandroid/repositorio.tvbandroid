                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.check.folders)]</property>
                          <property name="setting_description">Habilita esta opción y Play TVBan buscará resultados en tus carpetas de medios locales antes de revisar otros rastreadores habilitados.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=check.folders)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(60)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.provider.folders),true)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.check.folders),true)</visible>
