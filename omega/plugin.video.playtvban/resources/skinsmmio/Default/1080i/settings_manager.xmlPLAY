                          <property name="setting_type">action</property>
                          <property name="setting_value">empty_setting</property>
                          <property name="setting_description">Seleccione esta opción para activar una ventana de configuración que le permitirá establecer la ubicación de hasta 5 dispositivos que contengan archivos multimedia locales.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=sources_folders_choice)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(60)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.provider.folders),true)</visible>
                          <property name="setting_label">Filtrar Resultados por Nombre</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.folders.title_filter)]</property>
                          <property name="setting_description">Habilita esta opción y Play TVBan realizará funciones adicionales de coincidencia de nombres en los resultados de tus carpetas de medios locales. Esto ayudará a limitar los resultados incorrectos, pero también puede filtrar algunos resultados relevantes.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=folders.title_filter)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(60)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.provider.folders),true)</visible>
