                          <property name="setting_type">numeric</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.autoplay_watching_check)]</property>
                          <property name="setting_description">Choose after how many auto played episodes Play TVBan will ask if you are still watching. Set to 0 to disable</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_numeric&amp;setting_id=autoplay_watching_check)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.auto_play_episode),false)</visible>
                          <property name="setting_label">Extracción Automática de Datos Siguiente Episodio</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.autoscrape_next_episode)]</property>
                          <property name="setting_description">Habilita esta opción y Play TVBan buscará automáticamente fuentes para el Siguiente Episodio de una Serie de TV hacia el final del episodio que se está viendo actualmente.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=autoscrape_next_episode)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.auto_play_episode),false) + String.IsEqual(Window(10000).Property(playtvban.autoscrape_next_episode),true)</visible>
                          <property name="setting_label">    - Mostrar Notificación Después de (%) de la Reproducción</property>
                          <property name="setting_type">numeric</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.autoscrape_next_window_percentage)]</property>
                          <property name="setting_description">Elige cuándo Play TVBan mostrará la Alerta del Próximo Episodio.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_numeric&amp;setting_id=autoscrape_next_window_percentage)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.auto_play_episode),false) + String.IsEqual(Window(10000).Property(playtvban.autoscrape_next_episode),true)</visible>
                          <property name="setting_label">    - Utilice la Información del Capítulo Para Recibir Alertas Cuando Esté Disponible.</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.autoscrape_use_chapters)]</property>
                          <property name="setting_description">Habilite esta opción y Play TVBan intentará usar la información del Capítulo del archivo de video para determinar cuándo mostrar la alerta del Siguiente Episodio. Si no tiene éxito, se utilizará el porcentaje del valor de reproducción.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=autoscrape_use_chapters)</onclick>
                      </item>
                      
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.auto_play_episode),false) + String.IsEqual(Window(10000).Property(playtvban.autoscrape_next_episode),true)</visible>
                          <property name="setting_label">    - Confirmar Antes de Realizar el Rastreo Automático?</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.autoscrape_confirm)]</property>
                          <property name="setting_description">Habilita esta opción y Play TVBan confirmará que deseas realizar el escaneo automático del siguiente episodio hacia el final de la duración actual de los episodios.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=autoscrape_confirm)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <property name="setting_label">Reanudar la Reproducción Automáticamente</property>
                          <property name="setting_type">action</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.auto_resume_episode_name)]</property>
                          <property name="setting_description">Elige cuándo Play TVBan reanudará automáticamente la reproducción de un Episodio en curso.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_from_list&amp;setting_id=auto_resume_episode)</onclick>
                      </item>
        <!-- Playback Utilities -->
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <property name="setting_label">Utilidades de Reproducción</property>
                          <property name="setting_type">separator</property>
                          <onclick>noop</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <property name="setting_label">Limitar los Intentos de Resolución al Resultado Seleccionado.</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.playback.limit_resolve)]</property>
                          <property name="setting_description">Habilite esta opción y Play TVBan limitará los intentos de reproducción únicamente al resultado de origen seleccionado. Si está desactivada, Play TVBan intentará potencialmente 15 resultados con propiedades similares al resultado de origen seleccionado hasta que pueda resolverlo y reproducirlo correctamente.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=playback.limit_resolve)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.provider.easynews),true)</visible>
                          <visible>![String.IsEmpty(Window(10000).Property(playtvban.easynews_user)) + String.IsEmpty(Window(10000).Property(playtvban.easynews_password))]</visible>
                          <property name="setting_label">Método de Reproducción de EasyNews</property>
                          <property name="setting_type">action</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.easynews.playback_method_name)]</property>
                          <property name="setting_description">Seleccione el método que utilizará Play TVBan para optimizar la reproducción mediante EasyNews. REINTENTAR volverá a intentar el enlace una vez si falla la resolución (más lento). SIN BÚSQUEDA indicará a Kodi que el flujo no admite desplazamiento. Esto permite una resolución más rápida y estable, pero no podrá avanzar o retroceder fuera de la parte almacenada en caché. AMBOS utilizará ambos métodos. NINGUNO desactivará ambos métodos.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_from_list&amp;setting_id=easynews.playback_method)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.provider.easynews),true)</visible>
                          <visible>![String.IsEmpty(Window(10000).Property(playtvban.easynews_user)) + String.IsEmpty(Window(10000).Property(playtvban.easynews_password))]</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.easynews.playback_method),1) | String.IsEqual(Window(10000).Property(playtvban.easynews.playback_method),3)</visible>
                          <property name="setting_label">    - Establecer el Número Máximo de Reintentos Para la Reproducción</property>
                          <property name="setting_type">numeric</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.easynews.playback_method_retries)]</property>
                          <property name="setting_description">Seleccione el número máximo de reintentos permitidos para los intentos de reproducción de EasyNews.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_numeric&amp;setting_id=easynews.playback_method_retries)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.provider.easynews),true)</visible>
                          <visible>![String.IsEmpty(Window(10000).Property(playtvban.easynews_user)) + String.IsEmpty(Window(10000).Property(playtvban.easynews_password))]</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.easynews.playback_method),2) | String.IsEqual(Window(10000).Property(playtvban.easynews.playback_method),3)</visible>
                          <property name="setting_label">    - Excluir la reproducción SIN BÚSQUEDA para mis servicios</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.easynews.playback_method_limited)]</property>
                          <property name="setting_description">Habilite esta opción y Play TVBan no utilizará el método de reproducción EasyNews SIN BÚSQUEDA al resolver archivos regulares desde la ubicación Mis servicios -> EasyNews.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=easynews.playback_method_limited)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <property name="setting_label">Comprueba el Volumen Antes de Comenzar la Reproducción.</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.playback.volumecheck_enabled)]</property>
                          <property name="setting_description">Habilita esta opción y Play TVBan intentará comprobar el nivel de volumen actual en Kodi y ajustarlo a la baja si supera un nivel establecido.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=playback.volumecheck_enabled)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.playback.volumecheck_enabled),true)</visible>
                          <property name="setting_label">    - Establecer Porcentaje Máximo de Volumen inicial (0-100)</property>
                          <property name="setting_type">numeric</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.playback.volumecheck_percent)]</property>
                          <property name="setting_description">Seleccione el nivel de volumen máximo permitido</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_numeric&amp;setting_id=playback.volumecheck_percent)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <property name="setting_label">Subtítulos</property>
                          <property name="setting_type">separator</property>
                          <onclick>noop</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <property name="setting_label">Activación automática de subtítulos (Locales y de SubCreador)</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.playback.auto_enable_subs)]</property>
                          <property name="setting_description">Habilita la automatización de subtítulos durante la reproducción. Cuando esté activada, elige Subtítulos locales o SubMCreador (https://submaker.elfhosted.com).</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=playback.auto_enable_subs)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.playback.auto_enable_subs),true)</visible>
                          <property name="setting_label">    - Fuente del Subtítulo</property>
                          <property name="setting_type">action</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.playback.subs_source_name)]</property>
                          <property name="setting_description">Elige Subtítulos locales o SubMaker. Los subtítulos locales solo habilitan los que ya están en la transmisión. SubCreador (https://submaker.elfhosted.com) obtiene los subtítulos usando la URL de tu manifiesto que aparece a continuación.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_from_list&amp;setting_id=playback.subs_source)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.playback.auto_enable_subs),true)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.playback.subs_source),1)</visible>
                          <property name="setting_label">    - Lenguaje SubCreador</property>
                          <property name="setting_type">action</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.playback.submaker_language_name)]</property>
                          <property name="setting_description">Seleccione el idioma de subtítulos preferido para SubCreador. El idioma predeterminado es inglés.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_from_list&amp;setting_id=playback.submaker_language)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.playback.auto_enable_subs),true)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.playback.subs_source),1)</visible>
                          <property name="setting_label">    - Preferir Subtítulos Locales (Si Están Disponibles)</property>
                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.playback.submaker_prefer_local)]</property>
                          <property name="setting_description">Al usar SubCreador, primero verifique si hay subtítulos locales. Si los subtítulos locales están activos, Play TVBan los conservará y omitirá la descarga de SubMaker.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=playback.submaker_prefer_local)</onclick>
                      </item>
                      <item>
                          <visible>Container(2000).HasFocus(80)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.playback.auto_enable_subs),true)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.playback.subs_source),1)</visible>
                          <property name="setting_label">    - URL del manifiesto de SubCreador</property>
                          <property name="setting_type">string</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.playback.submaker_manifest)]</property>
                          <property name="setting_description">Introduzca la URL completa de su manifiesto de SubCreador desde https://submaker.elfhosted.com (debe incluir manifest.json). Ejemplo: https://.../manifest.json</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_string&amp;setting_id=playback.submaker_manifest)</onclick>
                      </item>
                </content>
            </control>
            <control type="group">
                <top>875</top>
                <left>15</left>
                <width>1685</width>
                <height>120</height>
                <!-- Match right-hand settings list vertical offset so INFO stays directly below it -->
                <animation effect="slide" end="0,-340" time="0" condition="Control.HasFocus(2100) + [Integer.IsEqual(Container(2100).NumItems,1) | Integer.IsEqual(Container(2100).NumItems,2)]">Conditional</animation>
                <animation effect="slide" end="0,-255" time="0" condition="Control.HasFocus(2100) + [Integer.IsEqual(Container(2100).NumItems,3) | Integer.IsEqual(Container(2100).NumItems,4)]">Conditional</animation>
                <animation effect="slide" end="0,-170" time="0" condition="Control.HasFocus(2100) + [Integer.IsEqual(Container(2100).NumItems,5) | Integer.IsEqual(Container(2100).NumItems,6)]">Conditional</animation>
                <animation effect="slide" end="0,-85" time="0" condition="Control.HasFocus(2100) + [Integer.IsEqual(Container(2100).NumItems,7) | Integer.IsEqual(Container(2100).NumItems,8)]">Conditional</animation>
                <animation effect="slide" end="0,-340" time="0" condition="Control.HasFocus(2000) + [Integer.IsEqual(Container(2000).NumItems,1) | Integer.IsEqual(Container(2000).NumItems,2)]">Conditional</animation>
                <animation effect="slide" end="0,-255" time="0" condition="Control.HasFocus(2000) + [Integer.IsEqual(Container(2000).NumItems,3) | Integer.IsEqual(Container(2000).NumItems,4)]">Conditional</animation>
                <animation effect="slide" end="0,-170" time="0" condition="Control.HasFocus(2000) + [Integer.IsEqual(Container(2000).NumItems,5) | Integer.IsEqual(Container(2000).NumItems,6)]">Conditional</animation>
                <animation effect="slide" end="0,-85" time="0" condition="Control.HasFocus(2000) + [Integer.IsEqual(Container(2000).NumItems,7) | Integer.IsEqual(Container(2000).NumItems,8)]">Conditional</animation>
                <control type="image">
                    <top>0</top>
                    <left>0</left>
                    <width>1685</width>
                    <height>120</height>
                    <texture colordiffuse="FF1A1A1A" border="20">playtvban_common/circle.png</texture>
                </control>
                <control type="label">
                    <top>12</top>
                    <left>30</left>
                    <width>200</width>
                    <height>24</height>
                    <font>font12</font> <!-- PLAYTVBAN_26 -->
                    <textcolor>FFCCCCCC</textcolor>
                    <label>[UPPERCASE][B]INFO: [/B][/UPPERCASE]</label>
                    <align>left</align>
                    <aligny>top</aligny>
                </control>
                <control type="group">
                    <top>8</top>
                    <left>115</left>
                    <width>1530</width>
                    <height>104</height>
                    <control type="textbox">
                        <left>0</left>
                        <top>0</top>
                        <width>1530</width>
                        <height>104</height>
                        <font>font12</font> <!-- PLAYTVBAN_26 -->
                        <align>left</align>
                        <aligny>top</aligny>
                        <textcolor>FFCCCCCC</textcolor>
                        <scrolltime>300</scrolltime>
                        <label>$INFO[Container(2100).ListItem.Property(setting_description)]</label>
                        <autoscroll delay="2000" time="2500" repeat="7000">true</autoscroll>
                        <visible>Control.HasFocus(2100)</visible>
                    </control>
                    <control type="textbox">
                        <left>0</left>
                        <top>0</top>
                        <width>1530</width>
                        <height>104</height>
                        <font>font12</font> <!-- PLAYTVBAN_26 -->
                        <align>left</align>
                        <aligny>top</aligny>
                        <textcolor>FFCCCCCC</textcolor>
                        <scrolltime>300</scrolltime>
                        <label>$INFO[Container(2000).ListItem.Property(setting_label),Todos los ajustes relacionados con [UPPERCASE][B],[/B][/UPPERCASE] Ajustes]</label>
                        <autoscroll delay="2000" time="2500" repeat="7000">true</autoscroll>
                        <visible>Control.HasFocus(2000)</visible>
                    </control>
                </control>
            </control>
            <control type="scrollbar" id="10025">
                <top>100</top>
                <left>1700</left>
                <width>10</width>
                <height>760</height>
                <texturesliderbackground colordiffuse="FF302F2F">playtvban_common/white.png</texturesliderbackground>
                <texturesliderbar colordiffuse="FF555556">playtvban_common/white.png</texturesliderbar>
                <texturesliderbarfocus colordiffuse="FFCCCCCC">playtvban_common/white.png</texturesliderbarfocus>
                <onleft>2100</onleft>
                <onright>2000</onright>
                <showonepage>false</showonepage>
                <orientation>vertical</orientation>
            </control>
        </control>
    </controls>
</window>
