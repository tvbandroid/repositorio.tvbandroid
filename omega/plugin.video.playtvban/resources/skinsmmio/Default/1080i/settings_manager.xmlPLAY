                          <property name="setting_type">boolean</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.use_viewtypes)]</property>
                          <property name="setting_description">Habilita esta opción para que Play TVBan controle los tipos de vista utilizados dentro del addon. Si está activada, las vistas pueden configurarse desde Herramientas -> Establecer vistas.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_boolean&amp;setting_id=use_viewtypes)</onclick>
                      </item>
