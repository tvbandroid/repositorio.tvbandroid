                          <visible>Container(2000).HasFocus(60)</visible>
                          <visible>String.IsEqual(Window(10000).Property(playtvban.provider.folders),true)</visible>
                          <property name="setting_label">Prioridad (Menor Número Equivale a Mayor Prioridad)</property>
                          <property name="setting_type">numeric</property>
                          <property name="setting_value">$INFO[Window(10000).Property(playtvban.folders.priority)]</property>
                          <property name="setting_description">Elija el orden en que aparecerán los resultados de las carpetas multimedia en relación con cualquier otra cuenta activa. Cuanto menor sea el número, mayor será el orden de clasificación.</property>
                          <onclick>RunPlugin(plugin://plugin.video.playtvban/?mode=settings_manager.set_numeric&amp;setting_id=folders.priority)</onclick>
                      </item>
<!-- RESULTS 70 -->
        <!-- Display -->
                      <item>
                          <visible>Container(2000).HasFocus(70)</visible>
